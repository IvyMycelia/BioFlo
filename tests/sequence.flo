import "bio/sequence.flo" as sequence

func main(): int
    failures: int = 0

    if not sequence.is_valid_dna_sequence("ACGTN"):
        print("FAIL: valid DNA was rejected\n")
        failures = failures + 1
    end

    if sequence.is_valid_dna_sequence("acxt"):
        print("FAIL: invalid DNA was accepted\n")
        failures = failures + 1
    end

    if sequence.is_valid_dna_sequence("acgt"):
        print("FAIL: lowercase DNA was accepted\n")
        failures = failures + 1
    end

    if sequence.is_valid_dna_sequence(""):
        print("FAIL: empty DNA was accepted\n")
        failures = failures + 1
    end

    if sequence.count_nucleotide("AACGTN", 'A') != 2:
        print("FAIL: incorrect nucleotide count for 'A'\n")
        failures = failures + 1
    end

    if sequence.gc_count("ACGT") != 2:
        print("FAIL: incorrect GC count\n")
        failures = failures + 1
    end

    if sequence.gc_content("ACGT") != 0.5:
        print("FAIL: incorrect GC content\n")
        failures = failures + 1
    end

    if sequence.gc_content("GCGC") != 1.0:
        print("FAIL: incorrect GC content for all GC sequence\n")
        failures = failures + 1
    end

    if sequence.gc_content("AAAA") != 0.0:
        print("FAIL: incorrect zero GC content\n")
        failures = failures + 1
    end

    if sequence.gc_content("") != 0.0:
        print("FAIL: incorrect GC content for empty sequence\n")
        failures = failures + 1
    end

    if failures == 0:
        print("All tests passed\n")
        return 0
    end

    print("Sequence tests failed: ")
    print(failures) print('\n')
    return 1
end